{
  "name": "blood-donation-management-system",
  "version": "1.0.0",
  "description": "A comprehensive blood donation management system backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "render-start": "node render-init.js && node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
